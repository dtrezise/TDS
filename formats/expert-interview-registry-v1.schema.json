{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dtrezise.github.io/TDS/formats/expert-interview-registry-v1.schema.json",
  "title": "TDS private expert interview registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "cases", "experts", "assignments", "outreach", "intake_briefs"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "created_on", "last_reviewed", "privacy"],
      "properties": {
        "schema_version": { "const": "1.0" },
        "created_on": { "type": "string", "format": "date" },
        "last_reviewed": { "type": "string", "format": "date" },
        "privacy": { "type": "string", "minLength": 1 }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["case_id", "title", "lane", "expert_domains", "interview_questions", "priority", "coverage_status", "last_reviewed"],
        "properties": {
          "case_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "lane": { "enum": ["legal", "conduct", "faith", "america", "deal"] },
          "expert_domains": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "interview_questions": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 1 } },
          "priority": { "enum": ["Critical", "High", "Medium", "Watch"] },
          "coverage_status": { "enum": ["Expert-ready", "Needs candidates", "Needs specialist review"] },
          "last_reviewed": { "type": "string", "format": "date" }
        }
      }
    },
    "experts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["expert_id", "name", "organization", "role", "expertise", "profile_url", "source_kind", "verified_on", "status"],
        "properties": {
          "expert_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "organization": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "expertise": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "profile_url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "contact_route_url": { "type": ["string", "null"], "format": "uri" },
          "source_kind": { "enum": ["Official profile", "Professional organization", "Reputable reporting", "Needs verification"] },
          "verified_on": { "type": "string", "format": "date" },
          "status": { "enum": ["Researching", "Verified candidate", "Do not contact", "Archived"] }
        }
      }
    },
    "assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["assignment_id", "case_id", "expert_id", "rank", "fit_rationale", "interview_angle", "status"],
        "properties": {
          "assignment_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "case_id": { "type": "string" },
          "expert_id": { "type": "string" },
          "rank": { "type": "integer", "minimum": 1 },
          "fit_rationale": { "type": "string", "minLength": 1 },
          "interview_angle": { "type": "string", "minLength": 1 },
          "status": { "enum": ["Candidate", "Alternate", "Hold", "Rejected"] }
        }
      }
    },
    "outreach": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["outreach_id", "case_id", "expert_id", "status", "dan_approval"],
        "properties": {
          "outreach_id": { "type": "string" },
          "case_id": { "type": "string" },
          "expert_id": { "type": "string" },
          "status": { "enum": ["Approved for outreach", "Contacted", "Interested", "Declined", "No response", "Interviewed", "Cleared for publication"] },
          "dan_approval": {
            "type": "object",
            "required": ["approved", "approved_on", "scope"],
            "properties": {
              "approved": { "const": true },
              "approved_on": { "type": "string", "format": "date" },
              "scope": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "intake_briefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["intake_id", "working_title", "publication_status", "expert_domains", "interview_questions", "source_urls", "candidate_expert_ids"],
        "properties": {
          "intake_id": { "type": "string" },
          "working_title": { "type": "string" },
          "publication_status": { "const": "Not a public eBox" },
          "expert_domains": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "interview_questions": { "type": "array", "minItems": 3, "items": { "type": "string" } },
          "source_urls": { "type": "array", "items": { "type": "string", "format": "uri" } },
          "candidate_expert_ids": { "type": "array", "minItems": 2, "items": { "type": "string" } }
        }
      }
    }
  }
}
